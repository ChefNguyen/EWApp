# ─────────────────────────────────────────────────────────────────────────────
# EWA Backend Environment Variables (Production)
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub credentials (for pulling images)
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_HUB_TOKEN=your_dockerhub_token

# Image tag to deploy (set by CI/CD pipeline, or use "latest" for manual deploy)
IMAGE_TAG=latest

# PostgreSQL Database (Neon.tech or your own)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=your_database_password

# Hibernate DDL mode (update for dev, validate for prod)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT Configuration
# Generate a secure random key: openssl rand -hex 32
JWT_SECRET=your_256bit_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Deployment directory on VM
DEPLOY_DIR=/opt/ewa
