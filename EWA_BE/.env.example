# ─────────────────────────────────────────────────────────────────────────────
# EWA Backend Environment Variables (Production)
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub credentials (for pulling images)
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_HUB_TOKEN=your_dockerhub_token

# Image tag to deploy (set by CI/CD pipeline, or use "latest" for manual deploy)
IMAGE_TAG=latest

# PostgreSQL Database (Supabase or your own)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.your_supabase_project_id
SPRING_DATASOURCE_PASSWORD=your_database_password

# Backend port
SERVER_PORT=8082

# Hibernate DDL mode (update for dev, validate for prod)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# OpenAI Chatbot
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# JWT Configuration
# Generate a secure random key: openssl rand -hex 32
JWT_SECRET=your_256bit_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Deployment directory on VM
DEPLOY_DIR=/opt/ewa

# SePay Sandbox (Withdrawal)
SEPAY_BASE_URL=https://bankhub-api-sandbox.sepay.vn
SEPAY_API_KEY=your_sepay_api_key
SEPAY_WEBHOOK_SECRET=your_webhook_secret_if_available

# Payment provider switches
EWA_WITHDRAWAL_PROVIDER=sepay
EWA_UTILITY_PROVIDER=mock
EWA_UTILITY_MOCK_FAILURE_RATE=0.05
EWA_UTILITY_MOCK_MIN_DELAY_MS=1000
EWA_UTILITY_MOCK_MAX_DELAY_MS=2000
